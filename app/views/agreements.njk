{% extends './layouts/layout.njk' %}
{% from "govuk/components/select/macro.njk" import govukSelect %}
{% block pageTitle %}
  Administration: AHWR Agreements
{% endblock %}
{% block content %}
  <form method="POST" action="/agreements">
    <div class="govuk-grid-row">
        <h1 class="govuk-heading-xl govuk-!-margin-bottom-7">Claims, Agreements and Flags</h1>
        <div class="govuk-grid-column-full">
          <div class="moj-scrollable-pane">
            <div class="moj-scrollable-pane__wrapper">
              <div class="govuk-tabs" data-module="govuk-tabs">
                <ul class="govuk-tabs__list">
                  <a class="govuk-tabs__list-item govuk-body" href="/claims">
                    <span class="govuk-tabs__tab">
                      Claims
                    </span>
                  </a>
                  <li class="govuk-tabs__list-item govuk-tabs__list-item--selected">
                    <span class="govuk-tabs__tab">
                      Agreements
                    </span>
                  </li>
                  <a class="govuk-tabs__list-item govuk-body" href="/flags">
                    <span class="govuk-tabs__tab">
                      Flags
                    </span>
                  </a>
                </ul>
                <div class="govuk-tabs__panel govuk-!-margin-bottom-6" id="agreements">
                  <div class="govuk-grid-column-two-thirds govuk-!-margin-bottom-9">
                    <h1 class="govuk-heading-l">Agreements</h1>
                    <div class="user-search-box">
                      <label class="govuk-label govuk-label--s" for="searchText">Find an agreement</label>
                      <div id="agreementSearch-hint" class="govuk-hint">Search by agreement number, organisation or SBI.</div>
                      <input type="hidden" name="crumb" value="{{crumb}}"/>
                      <input class="govuk-input" id="searchText" name="searchText" type="text" value="{{model.searchText}}" spellcheck="false">
                      <button class="search-button" data-module="govuk-button" name="submit" value="search">
                        Search
                      </button>
                    </div>
                  </div>
                  {% if model.error or error %}
                    <div class="govuk-grid-column-full">
                      <p class="govuk-body no-results-message">{{model.error}}{{error}}</p>
                    </div>
                  {% endif %}
                  <div class="govuk-grid-column-full">
                    {% call govukDetails({
                      summaryText: "Advanced search"
                      }) %}
                        {{ govukSelect({
                          id: "agreementType",
                          name: "agreementType",
                          label: {
                            text: "Agreement type"
                          },
                          items: model.agreementTypeOptions
                        }) }}
                        <div class="agreement-date-filters">
                          {{ govukDateInput({
                            id: "dateFrom",
                            namePrefix: "dateFrom",
                            fieldset: {
                              legend: {
                                text: "Agreement date from",
                                classes: "govuk-fieldset__legend--s"
                              }
                            },
                            items: model.agreementDateFrom
                          }) }}
                          {{ govukDateInput({
                            id: "dateTo",
                            namePrefix: "dateTo",
                            fieldset: {
                              legend: {
                                text: "Agreement date to",
                                classes: "govuk-fieldset__legend--s"
                              }
                            },
                            items: model.agreementDateTo
                          }) }}
                        </div>
                        <div class="govuk-button-group">
                          {{ govukButton({
                            text: "Search",
                            name: "submit",
                            value: "advancedSearch"
                          }) }}
                          <a class="govuk-link" href="/agreements/clear">Clear all filters</a>
                        </div>
                    {% endcall %}
                  </div>
                  <div class="govuk-grid-column-full">
                    <p class="govuk-body govuk-!-font-weight-bold">{{ model.total }} search results</p>
                  </div>

                    {{ govukTable({
                        attributes: {
                          'data-module': 'moj-sortable-table'
                        },
                        firstCellIsHeader: false,
                        head: model.header,
                        rows: model.applications
                      }) 
                    }}
                </div>
                {{ govukPagination({
                    previous: model.previous,
                    next: model.next,
                    items: model.pages
                  }) 
                }}
              </div>
            </div>
          </div>
        </div>
    </div>
  </form>
{% endblock %}
